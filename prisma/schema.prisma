generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMLAR ───────────────────────────────────────────

enum UserRole {
  ADMIN
  OMBORCHI
  KADR
  XODIM
}

enum ProductType {
  BERILADIGAN
  SARFLANADIGAN
}

enum UnitType {
  DONA
  PACHKA
  KOMPLEKT
}

enum AssetStatus {
  ACTIVE
  BROKEN
  LOST
  WRITTEN_OFF
}

enum OperationType {
  STOCK_IN
  GIVE_TO_DEPT
  RETURN_FROM_DEPT
  GIVE_TO_USER
  RETURN_FROM_USER
  TRANSFER_USER
  WRITE_OFF
  ASSIGN_TO_DEPT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

// ─── DEPARTMENT ─────────────────────────────────────────

model Department {
  id          String  @id @default(uuid())
  name        String
  description String?

  users            User[]
  departmentAssets DepartmentAsset[]
  operations       Operation[]
  assignments      Assignment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

// ─── USER ───────────────────────────────────────────────

model User {
  id           String  @id @default(uuid())
  fullName     String
  username     String  @unique
  passwordHash String
  phone        String?
  position     String?

  role     UserRole @default(XODIM)
  isActive Boolean  @default(true)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  assignments Assignment[]

  targetOperations    Operation[] @relation("OperationTargetUser")
  fromOperations      Operation[] @relation("OperationFromUser")
  performedOperations Operation[] @relation("OperationPerformer")

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([departmentId])
  @@index([role])
  @@index([deletedAt])
}

// ─── PRODUCT ────────────────────────────────────────────

model Product {
  id          String      @id @default(uuid())
  name        String
  year        Int?
  productType ProductType
  unit        UnitType    @default(DONA)
  description String?
  imageUrl    String?

  deletedAt DateTime?

  inventory        Inventory?
  assets           Asset[]
  departmentAssets DepartmentAsset[]
  operations       Operation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([productType])
  @@index([deletedAt])
}

// ─── INVENTORY ──────────────────────────────────────────

model Inventory {
  id        String @id @default(uuid())
  productId String @unique

  quantity   Int      @default(0)
  minLevel   Int      @default(0)
  unitPrice  Decimal? @db.Decimal(12, 2)
  totalValue Decimal? @db.Decimal(15, 2)

  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quantity])
}

// ─── ASSET (BERILADIGAN — har bir dona alohida) ─────────

model Asset {
  id String @id @default(uuid())

  productId       String
  inventoryNumber String      @unique
  serialNumber    String?
  status          AssetStatus @default(ACTIVE)

  purchaseDate  DateTime?
  purchasePrice Decimal?  @db.Decimal(12, 2)
  warrantyExp   DateTime?
  notes         String?

  product Product @relation(fields: [productId], references: [id])

  assignments Assignment[]
  operations  Operation[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([productId])
  @@index([status])
  @@index([inventoryNumber])
  @@index([deletedAt])
}

// ─── ASSIGNMENT ─────────────────────────────────────────

model Assignment {
  id String @id @default(uuid())

  userId       String?
  departmentId String?
  assetId      String

  assignedAt DateTime  @default(now())
  returnedAt DateTime?

  user       User?       @relation(fields: [userId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  asset      Asset       @relation(fields: [assetId], references: [id])

  @@index([userId])
  @@index([departmentId])
  @@index([assetId])
  @@index([userId, returnedAt])
  @@index([departmentId, returnedAt])
  @@index([assetId, returnedAt])
}

// ─── DEPARTMENT ASSET ───────────────────────────────────

model DepartmentAsset {
  id String @id @default(uuid())

  departmentId String
  productId    String
  quantity     Int @default(0)

  department Department @relation(fields: [departmentId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([departmentId, productId])
  @@index([departmentId])
  @@index([productId])
}

// ─── OPERATION ──────────────────────────────────────────

model Operation {
  id   String        @id @default(uuid())
  type OperationType

  quantity Int @default(1)

  productId    String
  assetId      String?
  departmentId String?
  userId       String?
  fromUserId   String?

  performedById String

  documentNumber String?
  documentDate   DateTime?
  note           String?

  product     Product     @relation(fields: [productId], references: [id])
  asset       Asset?      @relation(fields: [assetId], references: [id])
  department  Department? @relation(fields: [departmentId], references: [id])
  user        User?       @relation("OperationTargetUser", fields: [userId], references: [id])
  fromUser    User?       @relation("OperationFromUser", fields: [fromUserId], references: [id])
  performedBy User        @relation("OperationPerformer", fields: [performedById], references: [id])

  createdAt DateTime @default(now())

  @@index([type])
  @@index([productId])
  @@index([assetId])
  @@index([userId])
  @@index([departmentId])
  @@index([createdAt])
  @@index([documentNumber])
}

// ─── REFRESH TOKEN ──────────────────────────────────────

model RefreshToken {
  id String @id @default(uuid())

  userId    String
  tokenHash String

  expiresAt DateTime
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

// ─── AUDIT LOG ──────────────────────────────────────────

model AuditLog {
  id String @id @default(uuid())

  userId    String
  action    AuditAction
  tableName String
  recordId  String

  oldData Json?
  newData Json?

  ipAddress String?
  userAgent String?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tableName])
  @@index([recordId])
  @@index([createdAt])
}