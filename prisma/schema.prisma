generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//  ENUMLAR

enum UserRole {
  ADMIN
  OMBORCHI
  XODIM
}

enum ProductType {
  ASSET
  CONSUMABLE
  SHARED
}

enum UnitType {
  PIECE
  KG
  LITER
  PACK
}

enum AssetStatus {
  ACTIVE
  BROKEN
  LOST
  WRITTEN_OFF
}

enum OperationType {
  STOCK_IN

  GIVE_TO_USER
  RETURN_FROM_USER
  TRANSFER_USER

  GIVE_TO_DEPT
  ASSIGN_TO_DEPT
  RETURN_FROM_DEPT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

//  DEPARTMENT

model Department {
  id          String  @id @default(uuid())
  name        String
  code        String  @unique
  description String?

  users            User[]
  departmentAssets DepartmentAsset[]
  operations       Operation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//  USER

model User {
  id           String  @id @default(uuid())
  fullName     String
  username     String  @unique
  passwordHash String
  phone        String?
  email        String?
  position     String? // lavozim: Bosh mutaxassis, Direktor...

  role     UserRole @default(XODIM)
  isActive Boolean  @default(true)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  assignments Assignment[]

  targetOperations    Operation[] @relation("OperationTargetUser")
  fromOperations      Operation[] @relation("OperationFromUser")
  performedOperations Operation[] @relation("OperationPerformer")

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete — xodim ketsa arxivda qoladi

  @@index([departmentId])
  @@index([role])
  @@index([deletedAt])
}

//  PRODUCT

model Product {
  id          String      @id @default(uuid())
  name        String
  code        String?     @unique
  productType ProductType
  unit        UnitType    @default(PIECE)
  description String?
  imageUrl    String?
  isActive  Boolean   @default(true)
  deletedAt DateTime? // soft delete

  inventory        Inventory?
  assets           Asset[]
  departmentAssets DepartmentAsset[]
  operations       Operation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productType])
  @@index([isActive])
  @@index([deletedAt])
}

//  INVENTORY (markaziy ombor)

model Inventory {
  id String @id @default(uuid())
  productId String @unique
  quantity Int @default(0)
  minLevel Int @default(0)

  product Product @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quantity])
}

//  ASSET (ASSIGNABLE jihozlar — noutbuk, telefon...)

model Asset {
  id String @id @default(uuid())

  productId       String
  inventoryNumber String  @unique // INV-2024-001 — rasmiy inventar raqami
  code            String  @unique // ichki kod
  serialNumber    String? // seriya raqami
  status          AssetStatus @default(ACTIVE)
  purchaseDate  DateTime? // sotib olingan sana
  purchasePrice Decimal?  @db.Decimal(12, 2) // narxi
  warrantyExp   DateTime? // kafolat muddati
  notes String? // qo'shimcha izoh

  product Product @relation(fields: [productId], references: [id])

  assignments Assignment[]
  operations  Operation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([status])
  @@index([inventoryNumber])
}

//  ASSIGNMENT (xodimga biriktirilgan jihoz)

model Assignment {
  id String @id @default(uuid())

  userId  String
  assetId String

  user  User  @relation(fields: [userId], references: [id])
  asset Asset @relation(fields: [assetId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, assetId])
  @@index([userId])
  @@index([assetId])
}

//  DEPARTMENT ASSET (bo'limdagi CONSUMABLE va SHARED)

model DepartmentAsset {
  id String @id @default(uuid())

  departmentId String
  productId    String

  quantity Int @default(0)

  department Department @relation(fields: [departmentId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([departmentId, productId])
  @@index([departmentId])
  @@index([productId])
}

//  OPERATION (barcha harakatlar tarixi)

model Operation {
  id   String        @id @default(uuid())
  type OperationType
  quantity Int

  // GIVE_TO_USER, RETURN_FROM_USER, TRANSFER_USER (kimga)
  userId String?

  // TRANSFER_USER (kimdan)
  fromUserId String?

  assetId      String?
  productId    String
  departmentId String?

  performedById String

  // Rasmiy hujjat ma'lumotlari
  documentNumber String?   // AKT-2024-001
  documentDate   DateTime? // hujjat sanasi

  note String?

  user        User?       @relation("OperationTargetUser", fields: [userId], references: [id])
  fromUser    User?       @relation("OperationFromUser", fields: [fromUserId], references: [id])
  performedBy User        @relation("OperationPerformer", fields: [performedById], references: [id])
  asset       Asset?      @relation(fields: [assetId], references: [id])
  product     Product     @relation(fields: [productId], references: [id])
  department  Department? @relation(fields: [departmentId], references: [id])

  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([userId])
  @@index([fromUserId])
  @@index([productId])
  @@index([departmentId])
  @@index([documentNumber])
}

//  REFRESH TOKEN

model RefreshToken {
  id String @id @default(uuid())

  userId    String
  tokenHash String

  expiresAt DateTime
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
}

//  AUDIT LOG (tizim o'zgarishlari tarixi)

model AuditLog {
  id String @id @default(uuid())

  userId    String
  action    AuditAction // CREATE, UPDATE, DELETE
  tableName String      // qaysi jadval: "User", "Product", "Asset"...
  recordId  String      // o'zgartirilgan yozuvning id si

  oldData Json? // o'zgarishdan oldingi qiymat
  newData Json? // o'zgarishdan keyingi qiymat

  ipAddress String? // so'rov kelgan IP
  userAgent String? // browser / klient

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tableName])
  @@index([recordId])
  @@index([createdAt])
}
